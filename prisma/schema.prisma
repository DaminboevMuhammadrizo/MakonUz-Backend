generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
}

enum UserRole {
    ADMIN
    MANAGER
}

enum LocationType {
    COUNTRY
    REGION
    CITY
}

enum Status {
    ACTIVE
    INACTIVE
}

model User {
    id       Int      @id @default(autoincrement())
    fullname String
    phone    String   @unique
    pass     String?
    role     UserRole

    userPlace UserPlace[]
}

model UserPlace {
    id      Int @id @default(autoincrement())
    userId  Int
    placeId Int

    user  User  @relation(fields: [userId], references: [id])
    place Place @relation(fields: [placeId], references: [id])
}

model PlaceCategory {
    id     Int     @id @default(autoincrement())
    nameUz String  @unique
    nameRu String
    nameEn String
    img    String?

    place Place[]
}

model Place {
    id         Int      @id @default(autoincrement())
    locationId Int
    categoryId Int
    price      Float
    priceDesc  String?
    title      String
    desc       String
    ims        String[]
    video      String?
    phone      String
    telegram   String?
    link       String?
    status     Status
    views      Int      @default(0)

    location Location      @relation(fields: [locationId], references: [id])
    category PlaceCategory @relation(fields: [categoryId], references: [id])

    userPlace UserPlace[]
}

model Location {
    id        Int          @id @default(autoincrement())
    name      String
    type      LocationType
    parentId  Int?         @map("parent_id")
    createdAt DateTime     @default(now()) @map("created_at")
    updatedAt DateTime     @updatedAt @map("updated_at")

    parent Location? @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: Cascade)

    children Location[] @relation("LocationHierarchy")
    place    Place[]

    @@index([parentId])
    @@map("locations")
}
